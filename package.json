{
  "name": "nuxt-nats",
  "version": "0.1.0-alpha.2",
  "description": "Nuxt module for NATS JetStream — server-side publish, typed consumers, KV, stream provisioning",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nitro",
    "nats",
    "jetstream",
    "messaging",
    "pubsub",
    "kv",
    "object-store",
    "event-streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lithqube/nuxt-nats.git"
  },
  "bugs": {
    "url": "https://github.com/lithqube/nuxt-nats/issues"
  },
  "homepage": "https://github.com/lithqube/nuxt-nats#readme",
  "author": "lithqube",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "release:alpha": "npm run version:bump-alpha && npm run lint && npm run test:all && npm run prepack && npm publish --tag alpha && git add package.json package-lock.json && git commit -m \"chore: release $(node -p \\\"require('./package.json').version\\\")\" && git push",
    "release:stable": "npm run lint && npm run test:all && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=4096 vitest watch",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "version:print": "scripts/version.sh",
    "version:print-tag": "scripts/version.sh --tag",
    "version:bump-alpha": "npm version prerelease --preid=alpha --no-git-tag-version",
    "version:bump-minor": "npm version preminor --preid=alpha --no-git-tag-version",
    "version:bump-major": "npm version premajor --preid=alpha --no-git-tag-version"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/kv": "^3.4.0",
    "@nats-io/nats-core": "^3.4.0",
    "@nats-io/obj": "^3.4.0",
    "@nats-io/services": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "@nuxt/kit": "^4.4.6",
    "@synadia-ai/agent-service": "^0.5.2",
    "@synadia-ai/agents": "^0.5.2",
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@nats-io/nkeys": "^2.0.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "@nuxt/test-utils": "^4.0.3",
    "@testcontainers/nats": "^12.0.1",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.7",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "nuxt": "^4.4.4",
    "testcontainers": "^12.0.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
